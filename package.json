{
  "name": "throughline",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:smoke": "playwright test --config=playwright.config.ts tests/smoke",
    "test:e2e:routes": "playwright test --config=playwright.config.ts tests/routes",
    "test:a11y": "playwright test --config=playwright.config.ts tests/routes --grep @a11y",
    "test:lighthouse": "lhci autorun --config=./lighthouserc.json",
    "test:api": "vitest run --config=vitest.config.ts tests/api",
    "test:components": "vitest run --config=vitest.config.ts tests/components",
    "test:security": "vitest run --config=vitest.config.ts tests/security --exclude tests/security/**/*.integration.test.ts",
    "test:security:integration": "vitest run --config=vitest.config.ts tests/security/rate-limit.integration.test.ts",
    "test:ai": "vitest run --config=vitest.config.ts tests/ai",
    "test:ai:live": "AI_MODE=live tsx lib/ai/smoke.ts",
    "test:ats": "vitest run --config=vitest.config.ts tests/ats --exclude tests/ats/integration/**",
    "test:ats:integration": "ATS_INTEGRATION=1 vitest run --config=vitest.config.ts tests/ats/integration",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o .storybook-static",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.40.0",
    "@clerk/nextjs": "6.39.3",
    "@prisma/client": "5.22.0",
    "@tanstack/react-query": "5.100.10",
    "@upstash/ratelimit": "2.0.5",
    "@upstash/redis": "1.34.3",
    "inngest": "3.27.4",
    "lucide-react": "1.16.0",
    "next": "15.5.18",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "svix": "^1.93.0",
    "zod": "3.23.8",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "9.1.20",
    "@storybook/react-vite": "^9.1.20",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "22.10.5",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.18",
    "postcss": "8.4.49",
    "prisma": "5.22.0",
    "storybook": "9.1.20",
    "tailwindcss": "4.2.4",
    "tsx": "4.19.2",
    "typescript": "5.9.3",
    "vite": "^6",
    "vitest": "2.1.9"
  }
}
