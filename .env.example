# Throughline environment variables.
#
# Copy to .env.local for local dev and fill in real values. Production values
# are set in the Vercel dashboard, never committed.

# Neon Postgres — pooled connection for app runtime.
DATABASE_URL=

# Neon Postgres — direct connection used by `prisma migrate`.
DIRECT_URL=

# Neon Postgres — separate branch the ATS integration test seeds + cleans.
# Falls back to DATABASE_URL when absent (with a warning) so local devs can
# still run `pnpm test:ats:integration`. CI must set this to a dedicated
# Neon test branch URL.
DATABASE_URL_TEST=

# Clerk — publishable key is exposed to the browser.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk — server-only secret key.
CLERK_SECRET_KEY=

# Clerk — Svix signing secret for the user.* webhook receiver at
# /api/webhooks/clerk. Required for JIT User row provisioning to work.
CLERK_WEBHOOK_SIGNING_SECRET=

# Clerk — sign-in / sign-up route configuration.
# Clerk routing — these defaults wire Clerk to the Foundation-shipped routes; do not blank them.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Inngest — event key (publish) and signing key (verify).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Upstash Redis — REST credentials for AI cache + rate limit.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash Redis — separate test instance for rate-limit integration test.
# When unset, pnpm test:security:integration skips. Use a dedicated test
# database (NOT prod) — the suite writes to keys prefixed `tl:rl-test:`.
UPSTASH_REDIS_REST_URL_TEST=
UPSTASH_REDIS_REST_TOKEN_TEST=

# AI integration mode. `mock` returns fixtures; `live` calls the Anthropic SDK.
AI_MODE=mock

# ATS poller toggle. `disabled` short-circuits the Inngest scheduled job.
ATS_POLLER=disabled
